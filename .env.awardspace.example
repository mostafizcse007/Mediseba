# MediSeba AwardSpace Production Environment
APP_NAME=MediSeba
APP_ENV=production
APP_DEBUG=false
# AwardSpace free hosting does not support SSL, so use http unless you move to a plan/domain with HTTPS support.
APP_URL=http://your-awardspace-domain.example
APP_TIMEZONE=Asia/Dhaka

# Database
DB_HOST=your_awardspace_mysql_host
DB_PORT=3306
DB_DATABASE=your_awardspace_database
DB_USERNAME=your_awardspace_username
DB_PASSWORD=your_awardspace_database_password
DB_CHARSET=utf8mb4

# Security
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRY=86400
SESSION_LIFETIME=86400
CSRF_TOKEN_LIFETIME=3600

# OTP
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_PER_HOUR=5
OTP_DELIVERY_MODE=client_emailjs

# Email OTP Delivery
# AwardSpace free hosting blocks outgoing PHP connections, so use client-side EmailJS here.
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PRIVATE_KEY=

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_OTP=5
RATE_LIMIT_LOGIN=5
RATE_LIMIT_API=100

# CORS
CORS_ALLOWED_ORIGINS=http://your-awardspace-domain.example
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Authorization,X-Auth-Token,X-Requested-With,X-CSRF-Token

# Payment Gateway
PAYMENT_GATEWAY=demo
PAYMENT_GATEWAY_SECRET=replace_with_gateway_secret_for_live_callbacks
