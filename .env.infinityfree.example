# MediSeba InfinityFree Production Environment
APP_NAME=MediSeba
APP_ENV=production
APP_DEBUG=false
APP_URL=https://medisheba.infinityfree.me
APP_TIMEZONE=Asia/Dhaka

# Database
DB_HOST=sql300.infinityfree.com
DB_PORT=3306
DB_DATABASE=if0_41565265_mediseba
DB_USERNAME=if0_41565265
DB_PASSWORD=your_database_password
DB_CHARSET=utf8mb4

# Security
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRY=86400
SESSION_LIFETIME=86400
CSRF_TOKEN_LIFETIME=3600

# OTP
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_PER_HOUR=5
OTP_DELIVERY_MODE=server_emailjs

# Email OTP Delivery
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key_optional
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_OTP=5
RATE_LIMIT_LOGIN=5
RATE_LIMIT_API=100

# CORS
CORS_ALLOWED_ORIGINS=https://medisheba.infinityfree.me
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Authorization,X-Auth-Token,X-Requested-With,X-CSRF-Token

# Payment Gateway
# Use demo/sandbox for semester-project style direct in-app payment completion.
# Set to live only when you have a real payment gateway callback configured.
PAYMENT_GATEWAY=demo
PAYMENT_GATEWAY_SECRET=replace_with_gateway_secret_for_live_callbacks
